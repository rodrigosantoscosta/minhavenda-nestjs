# MinhaVenda NestJS — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to git

# ─── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=minhavenda
DB_PASSWORD=                     # Required. No default. Set a strong password.
DB_NAME=minhavenda

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# Must be at least 32 characters.
JWT_SECRET=
JWT_EXPIRATION=86400             # seconds — 86400 = 24 hours

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://minhavenda:minhavenda@localhost:5672

# ─── Email (Mailhog in dev) ───────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=noreply@minhavenda.com.br
MAIL_FROM_NAME=MinhaVenda

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Set to 'true' in development only. Set to 'false' in production.
SWAGGER_ENABLED=true

# ─── Rate Limiter ─────────────────────────────────────────────────────────────
# Comma-separated list of trusted proxy CIDR ranges (for X-Forwarded-For)
# Leave empty if not behind a proxy.
TRUSTED_PROXY_CIDRS=
